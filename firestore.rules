rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(eventId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/events/$(eventId)).data.createdBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /events/{eventId} {
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow read, update, delete: if isOwner(eventId);

      match /participants/{participantId} {
        allow read, write: if isOwner(eventId);
      }

      match /public_participants/{participantId} {
        allow read: if true;
        allow create, delete: if isOwner(eventId);
        allow update: if isOwner(eventId)
          || (
            resource.data.status == 'active'
            && request.resource.data.status in ['pending_payment', 'paid']
            && (
              request.resource.data.status == 'pending_payment'
              || (
                request.resource.data.status == 'paid'
                && get(/databases/$(database)/documents/events/$(eventId)).data.autoApproveReceipts == true
              )
            )
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt'])
          );
      }

      match /payments/{paymentId} {
        allow read, update, delete: if isOwner(eventId);

        allow create: if true
          && request.resource.data.eventId == eventId
          && (
            request.resource.data.status == 'pending'
            || (
              request.resource.data.status == 'approved'
              && get(/databases/$(database)/documents/events/$(eventId)).data.autoApproveReceipts == true
            )
          );
      }
    }

    match /public_events/{slug} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
